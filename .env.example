# Discord Bot Token
# Get this from the Discord Developer Portal
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Client ID (Application ID)
DISCORD_CLIENT_ID=your_client_id_here

# Google Gemini API Key
# Get this from Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter API Key
# Get this from https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- AI Model Pool Configuration ---
# Priority: The first model to try (can be a Gemini model, openrouter model, or g4f)
# Format: gemini:<model_name> | openrouter:<model_name> | g4f
# Example: AI_PRIORITY_MODEL=gemini:gemini-flash-latest
AI_PRIORITY_MODEL=gemini:gemini-flash-latest

# Pool: Comma-separated list of fallback models/providers tried in order if priority fails
# Example: AI_MODEL_POOL=gemini:gemini-2.5-flash-lite, openrouter:google/gemini-2.0-flash-001, g4f
AI_MODEL_POOL=gemini:gemini-2.5-flash-lite, g4f

# Max: Maximum number of fallback attempts before giving up
AI_MAX_RETRIES=3

# Debug Mode
DEBUG=false
